{
  "name": "@platforma-open/milaboratories.mixcr-clonotyping-2.model",
  "version": "1.25.2",
  "description": "Block model",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "sources": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "ts-builder build --target block-model && block-tools build-model",
    "watch": "ts-builder build --target block-model --watch",
    "type-check": "ts-builder type-check --target block-model",
    "test": "vitest run --passWithNoTests",
    "do-pack": "shx rm -f *.tgz && pnpm pack && shx mv *.tgz package.tgz",
    "fmt": "ts-builder format",
    "check": "ts-builder check --target block-model"
  },
  "dependencies": {
    "@milaboratories/helpers": "catalog:",
    "@platforma-sdk/model": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@milaboratories/ts-builder": "catalog:",
    "@milaboratories/ts-configs": "catalog:",
    "@platforma-sdk/block-tools": "catalog:",
    "@types/node": "*",
    "eslint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "*"
  }
}
